# MongoDB Environment Configuration
# Copy this file to .env and update with your actual values

# For Local MongoDB Installation
# MONGODB_URI=mongodb://localhost:27017/wellnest

# For MongoDB Atlas (Cloud)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/wellnest?retryWrites=true&w=majority

# For Development (default - local)
MONGODB_URI=mongodb://localhost:27017/wellnest

# Email Configuration (Update with your actual credentials)
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password